# .env.example
# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost/hazetrack2
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=hazetrack2

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-change-in-production

# JWT Configuration
JWT_SECRET_KEY=hazetrack-dev-secret-change-in-production
JWT_EXPIRY=24

# AI Models
YOLO_MODEL_PATH=yolov8n.pt
PLATE_CONF_THRESHOLD=0.45

# Processing
DEFAULT_FPS=30
FRAME_SKIP=1

# Logging
LOG_LEVEL=INFO

# Application
HOST=0.0.0.0
PORT=5000
DEBUG=True
